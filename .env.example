# OpenAI API key used when LLM_PROVIDER=openai.
OPENAI_API_KEY=

# Gemini Developer API key used when LLM_PROVIDER=gemini.
GEMINI_API_KEY=

# Alternative Gemini API key name supported by Google libraries.
GOOGLE_API_KEY=

# Selects the active LLM provider: openai, ollama, or gemini.
LLM_PROVIDER=ollama

# Base URL for the local or remote Ollama server.
OLLAMA_BASE_URL=http://localhost:11434

# Chat model used when LLM_PROVIDER=ollama.
OLLAMA_MODEL=gemma4:e2b

# Chat model used when LLM_PROVIDER=gemini.
GEMINI_MODEL=gemini-flash-latest

# Chat model used when LLM_PROVIDER=openai.
OPENAI_MODEL=gpt-5-nano

# Embedding model used for vector stores when LLM_PROVIDER=openai.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Embedding model used for vector stores when LLM_PROVIDER=ollama. Pull it first with: ollama pull nomic-embed-text
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Embedding model used for vector stores when LLM_PROVIDER=gemini.
GEMINI_EMBEDDING_MODEL=gemini-embedding-2-preview

# LangSmith API key used to trace LangChain runs.
LANGSMITH_API_KEY=

# Enables LangSmith tracing when set to true. The ch07 notebook also enables it automatically when LANGSMITH_API_KEY is present.
LANGSMITH_TRACING=true

# LangSmith API endpoint.
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# LangSmith project name where notebook traces are grouped.
LANGSMITH_PROJECT=Q & A chatbot

# Log file path for the ch05 LangGraph research pipeline.
CH05_LOG_FILE=logs/ch05-research.log

# Set to 1 to log full LLM prompts and responses in ch05.
CH05_LOG_LLM_DUMPS=0

# Set to 1 to log full LangGraph state instead of compact state summaries in ch05.
CH05_LOG_FULL_STATE=0

# Get APIKEY for AccuWeather at https://developer.accuweather.com/ and set it here to enable the ch05 weather agent example.
ACCUWEATHER_API_KEY=